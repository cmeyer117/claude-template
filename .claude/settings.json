{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fX*)",
      "Bash(git branch -D *)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(rm -rf *)",
      "Bash(sudo rm *)"
    ]
  }
}
