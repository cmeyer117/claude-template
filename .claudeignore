# .claudeignore — blocks junk files from Claude's context globally

# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.output/

# Package manager locks (large, rarely useful in context)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# Test coverage
coverage/
.nyc_output/

# Environment files (never send secrets to context)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# Cache directories
.cache/
.turbo/
.parcel-cache/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Type generation outputs (often large and auto-generated)
*.d.ts.map
*.js.map

# Large binary / media files
*.mp4
*.mp3
*.wav
*.mov
*.avi
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
*.woff
*.woff2
*.ttf
*.eot

# Database files
*.sqlite
*.sqlite3
*.db

# Compiled Python
*.pyc
*.pyo
*.pyd

# Terraform state (large, potentially sensitive)
*.tfstate
*.tfstate.backup
.terraform/

# Jupyter checkpoints
.ipynb_checkpoints/

# OS junk
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/

# Temporary files
*.tmp
*.temp
*.bak
*.orig
